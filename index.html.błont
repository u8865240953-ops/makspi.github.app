            background-color: #2563eb;
        }

        /* Sekcja Oferta/Projekty */
        .features {
            padding: 5rem 10%;
            background: #111827;
        }
        .section-title {
            text-align: center;
            font-size: 2rem;
            margin-bottom: 3rem;
        }
        .grid {
            display: grid;
